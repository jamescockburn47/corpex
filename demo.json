{
  "name": "Corpex — Corporate Intelligence",
  "description": "Companies House corporate investigation tool. Search companies, map ownership networks, analyse filings with AI, and export investigation reports.",
  "type": "desktop",
  "port": 8080,
  "path": "/vnc_lite.html",
  "healthCheck": "/vnc.html",
  "env": [
    {
      "key": "CH_API_KEY",
      "label": "Companies House API Key",
      "required": true,
      "byok": false,
      "helpUrl": "https://developer.company-information.service.gov.uk/"
    },
    {
      "key": "ANTHROPIC_API_KEY",
      "label": "Anthropic API Key",
      "required": true,
      "byok": true,
      "hint": "Get your key from console.anthropic.com",
      "helpUrl": "https://console.anthropic.com/settings/keys"
    },
    {
      "key": "OPENAI_API_KEY",
      "label": "OpenAI API Key (alternative to Anthropic)",
      "required": false,
      "byok": true,
      "hint": "Get your key from platform.openai.com",
      "helpUrl": "https://platform.openai.com/api-keys"
    }
  ],
  "resources": {
    "memory": "1g",
    "cpus": "1.0"
  },
  "tags": ["rust", "desktop", "companies-house", "investigation", "ai"]
}
